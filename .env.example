# ─── ENVIRONMENT ─────────────────────────────────────────────────────────────
# Server port
PORT=3001

# ─── EMAIL (Gmail SMTP via App Password) ─────────────────────────────────────
# Your Gmail address (the one that SENDS the notification)
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your normal password!)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=your_16_char_app_password

# Email address where contact messages are delivered (can be same as EMAIL_USER)
EMAIL_TO=your_gmail@gmail.com

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated, no spaces)
# Add your Vercel URL here after deploying the frontend
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://rishikarant-portfolio.vercel.app

# Admin token to protect GET /api/messages (choose any secret string)
ADMIN_TOKEN=my_super_secret_admin_token

